{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "archives/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "images/*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/archives/(.*)", "dest": "/archives/$1" },
    { "src": "/", "dest": "/home.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
