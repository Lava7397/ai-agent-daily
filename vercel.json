{
  "cleanUrls": false,
  "trailingSlash": true,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "functions": {
    "api/journal_url_preview.py": {
      "maxDuration": 20
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/home.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/today.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=120, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/issues.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=120, s-maxage=600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/journal.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=120, s-maxage=600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/issue-data/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/four-persimmons/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/journal-data.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=120, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/journal-submit.html",
      "headers": [
        { "key": "Cache-Control", "value": "private, max-age=0, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/today.html",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/home.html" }
  ]
}
